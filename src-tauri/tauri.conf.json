{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Passion",
  "version": "0.2.1",
  "identifier": "com.passion.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Passion",
        "width": 960,
        "height": 680,
        "minWidth": 960,
        "minHeight": 680,
        "maxWidth": 960,
        "maxHeight": 680,
        "resizable": false,
        "maximizable": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
